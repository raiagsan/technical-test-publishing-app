generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Author {
  id        Int      @id @default(autoincrement())
  name      String
  bio       String?
  books     Book[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("authors")
}

model Publisher {
  id        Int      @id @default(autoincrement())
  name      String
  address   String?
  books     Book[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("publishers")
}

model Book {
  id          Int       @id @default(autoincrement())
  title       String
  isbn        String?   @unique
  year        Int?
  authorId    Int
  publisherId Int
  author      Author    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  publisher   Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("books")
}